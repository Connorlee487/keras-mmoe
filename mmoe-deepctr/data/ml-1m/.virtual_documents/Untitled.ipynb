import pandas as pd

users = pd.read_csv(
    "users.dat",
    sep="::",
    engine="python",
    encoding="latin1",
    header=None,
    names=["user_id", "gender", "age", "occupation", "zip_code"]
)

users.head()


age_map = {
    1: "Under 18",
    18: "18-24",
    25: "25-34",
    35: "35-44",
    45: "45-49",
    50: "50-55",
    56: "56+"
}

users["age_group"] = users["age"].map(age_map)


occupation_map = {
    0: "other",
    1: "academic/educator",
    2: "artist",
    3: "clerical/admin",
    4: "college/grad student",
    5: "customer service",
    6: "doctor/health care",
    7: "executive/managerial",
    8: "farmer",
    9: "homemaker",
    10: "K-12 student",
    11: "lawyer",
    12: "programmer",
    13: "retired",
    14: "sales/marketing",
    15: "scientist",
    16: "self-employed",
    17: "technician/engineer",
    18: "tradesman/craftsman",
    19: "unemployed",
    20: "writer"
}

users["occupation_name"] = users["occupation"].map(occupation_map)


users.head()
